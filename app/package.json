    "react-dom": "^19.1.0",
    "react-hot-toast": "^2.5.2",
    "slugify": "^1.6.6",
    "tailwind-merge": "^3.3.0",
    "zod": "^3.25.51"
  },
  "devDependencies": {
    "eslint": "^9.28.0",
