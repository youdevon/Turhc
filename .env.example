# App
APP_NAME="Infrastructure Website CMS"
APP_PORT=3010
APP_URL="http://localhost:3010"

# Additional applications (docker-compose services)
IMGMT_NAME=iMgMT
IMGMT_PORT=3011
IMGMT_URL="http://localhost:3011"
IMGMT_NEXTAUTH_SECRET=change_this_to_a_long_random_secret_for_imgmt

# iMgMT database (separate from CMS)
IMGMT_DB_PORT=5438
IMGMT_POSTGRES_DB=imgmt
IMGMT_POSTGRES_USER=imgmt_user
IMGMT_POSTGRES_PASSWORD=change_this_imgmt_password
# Local dev: postgresql://imgmt_user:change_this_imgmt_password@localhost:5438/imgmt
IMGMT_DATABASE_URL="postgresql://imgmt_user:change_this_imgmt_password@imgmt-db:5432/imgmt?schema=public"

# iMgMT auth & seed
IMGMT_ADMIN_EMAIL=admin@imgmt.local
IMGMT_ADMIN_PASSWORD=ChangeMe123!
IMGMT_RUN_SEED=true

# iMgMT file storage (Docker volume mounted at /var/app-data/files)
FILE_STORAGE_ROOT="/var/app-data/files"
NEXT_PUBLIC_APP_URL="http://localhost:3010"
NEXTAUTH_URL="http://localhost:3010"
NEXTAUTH_SECRET=change_this_to_a_long_random_secret

# Database
POSTGRES_DB=infrastructure_cms
POSTGRES_USER=infrastructure_user
POSTGRES_PASSWORD=change_this_password
DATABASE_URL="postgresql://infrastructure_user:change_this_password@db:5432/infrastructure_cms?schema=public"

# Auth (legacy alias - NEXTAUTH_SECRET is used by NextAuth)
AUTH_SECRET=change_this_to_a_long_random_secret
ADMIN_EMAIL=admin@infrastructure.local
ADMIN_PASSWORD=ChangeMe123!

# Uploads
UPLOAD_DIR="/app/uploads"
MAX_UPLOAD_SIZE_MB=100

# Docker seed on first deploy only (set RUN_SEED=true once, then back to false)
RUN_SEED=false

# Appearance (also managed via CMS Site Settings)
# activeTheme: dark | light
# primaryAccentColor, secondaryAccentColor, heroOverlayDarkness

# SMTP — fallback when not configured in Admin → Site Settings → Email / SMTP
# CMS settings take precedence when SMTP host and from email are saved there.
SMTP_ENABLED=true
SMTP_HOST=
SMTP_PORT=587
SMTP_ENCRYPTION=starttls
# Legacy alias: SMTP_SECURE=true maps to SSL when SMTP_ENCRYPTION is unset
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME="Website Enquiries"
SMTP_REPLY_TO=
ENQUIRY_FORWARD_TO=
ENQUIRY_FORWARD_CC=
ENQUIRY_FORWARD_BCC=
