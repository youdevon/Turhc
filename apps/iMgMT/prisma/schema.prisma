generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  ON_LEAVE
  SUSPENDED
  EXITED
}

enum EmploymentType {
  PERMANENT
  CONTRACT
  TEMPORARY
}

enum DocumentCategory {
  QUALIFICATION
  REPORT
  CONTRACT
  MEDICAL_CERTIFICATE
  ID
  OTHER
}

enum ContractStatus {
  ACTIVE
  EXPIRED
  RENEWED
  TERMINATED
}

enum AssetStatus {
  IN_STORE
  ASSIGNED
  REPAIR
  RETIRED
}

enum LeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ApprovalStepStatus {
  PENDING
  APPROVED
  REJECTED
  SKIPPED
}

enum EmailJobStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Department {
  id           String       @id @default(cuid())
  name         String
  parentId     String?
  parent       Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children     Department[] @relation("DepartmentHierarchy")
  headUserId   String?
  headUser     User?        @relation("DepartmentHead", fields: [headUserId], references: [id])
  users        User[]       @relation("UserDepartment")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([parentId])
}

model User {
  id                 String            @id @default(cuid())
  firstName          String
  lastName           String
  email              String            @unique
  phone              String?
  employeeNumber     String?           @unique
  passwordHash       String
  dateOfEmployment   DateTime          @db.Date
  employmentType     EmploymentType    @default(PERMANENT)
  jobTitle           String?
  departmentId       String?
  department         Department?       @relation("UserDepartment", fields: [departmentId], references: [id])
  status             UserStatus        @default(ACTIVE)
  roleId             String
  role               Role              @relation(fields: [roleId], references: [id])
  lastLoginAt        DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  headedDepartments  Department[]      @relation("DepartmentHead")
  reportingAsEmployee ReportingLine[]  @relation("ReportingEmployee")
  reportingAsAuthority ReportingLine[] @relation("ReportingAuthority")
  delegationsGiven   Delegation[]      @relation("Delegator")
  delegationsReceived Delegation[]     @relation("Delegate")
  delegationsCreated Delegation[]      @relation("DelegationCreator")
  contracts          Contract[]
  documents          Document[]        @relation("DocumentOwner")
  documentsUploaded  Document[]        @relation("DocumentUploader")
  qualifications     Qualification[]
  assetAssignments   AssetAssignment[] @relation("AssignmentUser")
  assetsAssigned     AssetAssignment[] @relation("AssignmentAssigner")
  assetsReceived     AssetAssignment[] @relation("AssignmentReceiver")
  leaveBalances      LeaveBalance[]
  leaveRequests      LeaveRequest[]
  approvalStepsAssigned ApprovalStep[] @relation("AssignedAuthority")
  approvalStepsActed ApprovalStep[]    @relation("ActedBy")
  notifications      Notification[]
  auditLogs          AuditLog[]        @relation("AuditActor")
  auditLogsActingFor AuditLog[]        @relation("AuditActingFor")

  @@index([departmentId])
  @@index([roleId])
  @@index([status])
}

model ReportingLine {
  id            String    @id @default(cuid())
  employeeId    String
  employee      User      @relation("ReportingEmployee", fields: [employeeId], references: [id])
  authorityId   String
  authority     User      @relation("ReportingAuthority", fields: [authorityId], references: [id])
  level         Int
  isPrimary     Boolean   @default(false)
  effectiveFrom DateTime  @db.Date
  effectiveTo   DateTime? @db.Date
  createdAt     DateTime  @default(now())

  @@index([employeeId, effectiveTo])
  @@index([authorityId, effectiveTo])
  @@index([employeeId, level, effectiveTo])
}

model Delegation {
  id          String   @id @default(cuid())
  delegatorId String
  delegator   User     @relation("Delegator", fields: [delegatorId], references: [id])
  delegateId  String
  delegate    User     @relation("Delegate", fields: [delegateId], references: [id])
  startDate   DateTime @db.Date
  endDate     DateTime @db.Date
  reason      String?
  createdById String
  createdBy   User     @relation("DelegationCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  @@index([delegatorId, startDate, endDate])
  @@index([delegateId, startDate, endDate])
}

model Contract {
  id         String         @id @default(cuid())
  userId     String
  user       User           @relation(fields: [userId], references: [id])
  type       String
  startDate  DateTime       @db.Date
  endDate    DateTime?      @db.Date
  documentId String?
  document   Document?      @relation(fields: [documentId], references: [id])
  status     ContractStatus @default(ACTIVE)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([userId])
  @@index([endDate, status])
}

model Document {
  id           String           @id @default(cuid())
  userId       String
  user         User             @relation("DocumentOwner", fields: [userId], references: [id])
  category     DocumentCategory
  title        String
  description  String?
  fileName     String
  mimeType     String
  sizeBytes    Int
  storagePath  String
  sha256       String?
  uploadedById String
  uploadedBy   User             @relation("DocumentUploader", fields: [uploadedById], references: [id])
  uploadedAt   DateTime         @default(now())
  contracts    Contract[]
  qualifications Qualification[]
  leaveRequests LeaveRequest[]

  @@index([userId, category])
}

model Qualification {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  documentId   String?
  document     Document? @relation(fields: [documentId], references: [id])
  title        String
  institution  String?
  dateAttained DateTime  @db.Date
  expiryDate   DateTime? @db.Date
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
  @@index([expiryDate])
}

model Asset {
  id           String            @id @default(cuid())
  assetTag     String            @unique
  name         String
  category     String
  serialNumber String?
  status       AssetStatus       @default(IN_STORE)
  assignments  AssetAssignment[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

model AssetAssignment {
  id              String    @id @default(cuid())
  assetId         String
  asset           Asset     @relation(fields: [assetId], references: [id])
  userId          String
  user            User      @relation("AssignmentUser", fields: [userId], references: [id])
  assignedAt      DateTime  @default(now())
  assignedById    String
  assignedBy      User      @relation("AssignmentAssigner", fields: [assignedById], references: [id])
  returnedAt      DateTime?
  returnCondition String?
  receivedById    String?
  receivedBy      User?     @relation("AssignmentReceiver", fields: [receivedById], references: [id])

  @@index([userId, returnedAt])
  @@index([assetId, returnedAt])
}

model LeaveType {
  id                          String         @id @default(cuid())
  name                        String         @unique
  defaultEntitlement          Float?
  requiresCertificateAfterDays Int?
  drawsFromBalance            Boolean        @default(true)
  color                       String         @default("#3b82f6")
  active                      Boolean        @default(true)
  notes                       String?
  balances                    LeaveBalance[]
  leaveRequests               LeaveRequest[]
  createdAt                   DateTime       @default(now())
  updatedAt                   DateTime       @updatedAt
}

model LeaveBalance {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  leaveTypeId  String
  leaveType    LeaveType @relation(fields: [leaveTypeId], references: [id])
  year         Int
  entitled     Float     @default(0)
  carriedOver  Float     @default(0)
  adjusted     Float     @default(0)
  used         Float     @default(0)
  pending      Float     @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([userId, leaveTypeId, year])
  @@index([userId, year])
}

model Holiday {
  id        String   @id @default(cuid())
  date      DateTime @db.Date
  name      String
  year      Int
  isMovable Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([date])
  @@index([year])
}

model LeaveRequest {
  id                    String             @id @default(cuid())
  userId                String
  user                  User               @relation(fields: [userId], references: [id])
  leaveTypeId           String
  leaveType             LeaveType          @relation(fields: [leaveTypeId], references: [id])
  startDate             DateTime           @db.Date
  endDate               DateTime           @db.Date
  calculatedDays        Float
  reason                String?
  status                LeaveRequestStatus @default(PENDING)
  certificateDocumentId String?
  certificateDocument   Document?          @relation(fields: [certificateDocumentId], references: [id])
  certificateRequired   Boolean            @default(false)
  certificateOutstanding Boolean           @default(false)
  createdAt             DateTime           @default(now())
  decidedAt             DateTime?
  approvalSteps         ApprovalStep[]

  @@index([userId, status])
  @@index([startDate, endDate])
}

model ApprovalStep {
  id                  String             @id @default(cuid())
  leaveRequestId      String
  leaveRequest        LeaveRequest       @relation(fields: [leaveRequestId], references: [id], onDelete: Cascade)
  level               Int
  assignedAuthorityId String
  assignedAuthority   User               @relation("AssignedAuthority", fields: [assignedAuthorityId], references: [id])
  actedById           String?
  actedBy             User?              @relation("ActedBy", fields: [actedById], references: [id])
  status              ApprovalStepStatus @default(PENDING)
  comment             String?
  actedAt             DateTime?
  createdAt           DateTime           @default(now())

  @@index([leaveRequestId, level])
  @@index([assignedAuthorityId, status])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  title     String
  body      String
  link      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
}

model AuditLog {
  id           String   @id @default(cuid())
  timestamp    DateTime @default(now())
  actorId      String?
  actor        User?    @relation("AuditActor", fields: [actorId], references: [id])
  actingForId  String?
  actingFor    User?    @relation("AuditActingFor", fields: [actingForId], references: [id])
  action       String
  entityType   String?
  entityId     String?
  before       Json?
  after        Json?
  ip           String?
  userAgent    String?

  @@index([timestamp])
  @@index([actorId, timestamp])
  @@index([entityType, entityId])
  @@index([action, timestamp])
}

model EmailJob {
  id           String         @id @default(cuid())
  toEmail      String
  subject      String
  htmlBody     String
  status       EmailJobStatus @default(PENDING)
  attempts     Int            @default(0)
  lastError    String?
  scheduledFor DateTime       @default(now())
  sentAt       DateTime?
  createdAt    DateTime       @default(now())

  @@index([status, scheduledFor])
}

model AppSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  label     String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}
